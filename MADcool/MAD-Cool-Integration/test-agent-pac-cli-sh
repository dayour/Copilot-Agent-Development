# Step 5: Get bot components
echo "Step 5: Querying bot components..."
cat > /tmp/fetch_components.xml << 'EOF'
<fetch>
  <entity name="botcomponent">
    <attribute name="name" />
    <attribute name="componenttype" />
    <filter>
      <condition attribute="parentbotid" operator="eq" value="d09c19a2-7175-f011-b4cb-6045bd055517" />
    </filter>
  </entity>
</fetch>
EOF

pac org fetch --xmlFile /tmp/fetch_components.xml
echo ""

