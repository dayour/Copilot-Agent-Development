# Direct Line secret from Copilot Studio > Settings > Channels > Direct Line
# Used by the token-server to exchange for a short-lived client token
DIRECT_LINE_SECRET=your_direct_line_secret_here

# Bot ID from your Copilot Studio agent settings or the agent URL
# For reference when customising web-chat/index.html
AGENT_BOT_ID=your_bot_id_here
