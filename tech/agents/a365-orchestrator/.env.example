# Local environment variables for A365 Orchestrator
# Copy this file to .env and fill in all values before running locally.

# ---- Bot identity ----
BOT_ID=
BOT_PASSWORD=
TENANT_ID=

# ---- IT Help Desk specialist agent ----
IT_HELP_DESK_ENVIRONMENT_ID=
IT_HELP_DESK_SCHEMA_NAME=cr123_itHelpDesk

# ---- Calendar Manager specialist agent ----
CALENDAR_MANAGER_ENVIRONMENT_ID=YOUR_ENVIRONMENT_ID
CALENDAR_MANAGER_SCHEMA_NAME=dystudio_calendarManager

# ---- Knowledge Base specialist agent ----
KNOWLEDGE_BASE_ENVIRONMENT_ID=
KNOWLEDGE_BASE_SCHEMA_NAME=cr123_knowledgeBase

# ---- Azure infrastructure ----
APPLICATIONINSIGHTS_CONNECTION_STRING=
KEY_VAULT_URI=

# ---- Server ----
PORT=3978
