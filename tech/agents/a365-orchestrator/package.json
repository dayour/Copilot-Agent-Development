{
  "name": "a365-orchestrator",
  "version": "1.0.0",
  "description": "M365 Agents SDK orchestrator that routes Teams conversations to specialist Copilot Studio agents.",
  "license": "MIT",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "npx rimraf ./dist",
    "build": "npx tsup",
    "start": "node .",
    "dev": "npx nodemon -w \"./src/**\" -e ts --exec \"node -r ts-node/register -r dotenv/config ./src/index.ts\"",
    "test": "npx jest --passWithNoTests"
  },
  "dependencies": {
    "@azure/msal-node": "^3.6.3",
    "@microsoft/agents-copilotstudio-client": "^0.6.1",
    "@microsoft/teams.apps": "preview",
    "@microsoft/teams.dev": "^2.0.0-preview.7"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.5.4",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
